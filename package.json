{
  "name": "zvoove-angular-components",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve zvoove-components-demo",
    "build": "ng build",
    "build:components": "npm run build:components-lib && npm run build:components-schematics",
    "build:components-demo": "ng build zvoove-components-demo --configuration production",
    "build:components-lib": "ng build components --configuration production",
    "build:components-schematics": "tsc -p projects/components/tsconfig.schematics.json",
    "test": "ng test",
    "test:components": "ng test components --watch=false --no-progress",
    "test:schematics": "npm run build:components-schematics && vitest run --config vitest.config.schematics.ts",
    "lint": "ng lint",
    "commit": "git-cz",
    "release:test": "ng lint components && ng test components --watch=false",
    "copy:schemas": "copyfiles -u 3 projects/components/schematics/*/schema.json dist/components/schematics/",
    "copy:files": "copyfiles -u 3 projects/components/schematics/*/files/** dist/components/schematics/",
    "copy:collection": "copyfiles -f projects/components/schematics/migrations.json dist/components/schematics/",
    "postbuild:components-schematics": "npm run copy:schemas && npm run copy:files && npm run copy:collection",
    "prepare": "husky",
    "serve:ssr:zvoove-components-demo": "node dist/zvoove-components-demo/server/server.mjs"
  },
  "private": false,
  "dependencies": {
    "@angular-devkit/core": "^21.2.10",
    "@angular-devkit/schematics": "^21.2.10",
    "@angular/cdk": "^21.2.10",
    "@angular/common": "^21.2.12",
    "@angular/compiler": "^21.2.12",
    "@angular/core": "^21.2.12",
    "@angular/forms": "^21.2.12",
    "@angular/material": "^21.2.10",
    "@angular/platform-browser": "^21.2.12",
    "@angular/platform-browser-dynamic": "^21.2.12",
    "@angular/platform-server": "^21.2.12",
    "@angular/router": "^21.2.12",
    "@angular/ssr": "^21.2.10",
    "express": "^5.2.1",
    "ngx-highlightjs": "^14.0.1",
    "ngx-mat-select-search": "^8.0.5",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.10",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.12",
    "@angular/language-service": "^21.2.12",
    "@angular/localize": "^21.2.12",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.3",
    "@vitest/browser-playwright": "^4.1.6",
    "@vitest/eslint-plugin": "^1.6.17",
    "angular-eslint": "^21.3.1",
    "copyfiles": "^2.4.1",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "ng-packagr": "^21.2.3",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.1"
  },
  "lint-staged": {
    "*.{ts,json,scss,html}": "prettier --write"
  },
  "overrides": {
    "eslint-plugin-vitest": {
      "eslint": "$eslint"
    }
  }
}
